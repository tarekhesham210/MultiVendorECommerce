@using Microsoft.AspNetCore.Identity
@model List<IdentityRole>
@{
    ViewData["Title"] = "Roles";
}

<h2>Roles</h2>

<a asp-action="CreateRole" class="btn btn-success mb-3">Create New Role</a>
<table class="table">
    <thead>
        <tr>
            <th>Role Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var role in Model)
{
            <tr>
                <td>@role.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-primary">Edit</a>

                    <form asp-action="DeleteRole" asp-route-id="@role.Id" method="post" onsubmit="return confirm('Are you sure?');"class="d-inline" >
                        <button type="submit" class="btn btn-danger ">Delete</button>
                    </form>

                </td>
            </tr>
        }
    </tbody>
</table>
