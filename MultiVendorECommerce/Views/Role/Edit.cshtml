@using MultiVendorECommerce.ViewModels
@model RolePermissionsVM
<form asp-action="EditRolePermissions" method="post">
    <input type="hidden" asp-for="RoleId" />

    <div asp-validation-summary="All" class="text-danger"></div>

    <h3>Editing Permissions for Role: @Model.RoleName</h3>

    <div class="form-group">
        @for (int i = 0; i < Model.Permissions.Count; i++)
        {
            <div class="form-check mb-2">
                <input type="checkbox"
                       asp-for="Permissions[i].IsSelected"
                       class="form-check-input" />

                <label class="form-check-label">
                    @Model.Permissions[i].Name
                </label>

                <input type="hidden" asp-for="Permissions[i].Name" />
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary mt-3">
        Save Permissions
    </button>
</form>