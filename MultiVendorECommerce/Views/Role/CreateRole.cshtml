@using MultiVendorECommerce.ViewModels
@model RoleVM
<form asp-action="AddRole" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <label asp-for="Name" class="form-label">Role Name</label>
    <input type="text" asp-for="Name" placeholder="Role Name" class="form-control" />
    <span asp-validation-for="Name" class="text-danger"></span>
    <button type="submit" class="btn btn-primary mt-3">Create Role</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}