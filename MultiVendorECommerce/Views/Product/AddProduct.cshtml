@using PermissionBasedAuz.ViewModels
@model AddProductVM
<form asp-action="AddProduct"
      asp-controller="Product"
      method="post"
      enctype="multipart/form-data">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group mb-3">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="CaegoryId"></label>
        <select asp-for="CaegoryId"
                asp-items="@Model.Categories"
                class="form-select">
            <option value="">-- Select Category --</option>
        </select>
        <span asp-validation-for="CaegoryId" class="text-danger"></span>
    </div>

    

    <div class="form-group mb-3">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Price"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label asp-for="StockQuantity"></label>
        <input asp-for="StockQuantity" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="ProductImages"></label>
        <input asp-for="ProductImages"
               type="file"
               multiple
               class="form-control" accept="@ImageSettings.AllowedExtensions" />
        <span asp-validation-for="ProductImages" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">
        Add Product
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}









