@model dynamic
@{
    var urlTemplate = ViewData["UrlTemplate"] as string;
}

<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center">
        <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
             <a class="page-link" href="@urlTemplate.Replace("{page}", (Model.CurrentPage - 1).ToString())">Previous</a>
         </li>

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                 <a class="page-link" href="@urlTemplate.Replace("{page}", i.ToString())">@i</a>
             </li>
        }

        <li class="page-item @(Model.HasNext ? "" : "disabled")">
             <a class="page-link" href="@urlTemplate.Replace("{page}", (Model.CurrentPage + 1).ToString())">Next</a>
         </li>
    </ul>
</nav>