@model CategoryProductsVM
@{
    ViewData["Title"] = "Products";
}
<div class="container-fluid pt-5">
    <div class="text-center mb-4">
        <h2 class="section-title px-5"><span class="px-2">@Model.CategoryName</span></h2>
    </div>
    <div class="row px-xl-5 pb-3">
            @foreach (var product in Model.Products)
            {
            <div class="col-lg-3 col-md-6 col-sm-12 pb-1">

                <div class="card product-item border-0 mb-4">
                    <div class="card-header product-img position-relative overflow-hidden bg-transparent border p-0">
                        <a asp-action="ProductDetails"
                            asp-controller="Home"
                        asp-route-productId="@product.ProductId"
                        asp-route-variantId="@product.Id">
                        <img class="img-fluid w-100" src="@ImageSettings.GetImageUrl(ImageSettings.ProudctsImagesFolder,product.MainImageUrl)" alt="">
                        </a>
                    </div>
                <div class="card-body border-left border-right text-center p-0 pt-4 pb-3">
                    <h6 class="text-truncate mb-3">@product.Name</h6>
                        @if (product.HasOffer)
                        {
                            <div class="d-flex justify-content-center">
                                <h6>@product.FinalPrice</h6><h6 class="text-muted ml-2"><del>@product.Price</del></h6>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-center">
                                <h6>@product.Price</h6>
                            </div>
                        }

                </div>
                <div class="card-footer d-flex justify-content-between bg-light border">
                        <a asp-action="ProductDetails" asp-route-productId="@product.ProductId" asp-route-variantId="@product.Id" class="btn btn-sm text-dark p-0"><i class="fas fa-eye text-primary mr-1"></i>View Detail</a>
                        @Html.AntiForgeryToken()
                        <button type="button"
                                onclick="addToCart(@product.Id, 1)"
                                class="btn btn-sm text-dark p-0">
                            <i class="fas fa-shopping-cart text-primary mr-1"></i> Add To Cart
                        </button>
                </div>
            </div>
            </div>

            }

    </div>
</div>
@section Scripts {
  
}