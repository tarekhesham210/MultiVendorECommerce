@model CartDetailsVM
<!-- Page Header StartVM -->
<div class="container-fluid bg-secondary mb-5">
    <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 300px">
        <h1 class="font-weight-semi-bold text-uppercase mb-3">Shopping Cart</h1>
        <div class="d-inline-flex">
            <p class="m-0"><a href="">Home</a></p>
            <p class="m-0 px-2">-</p>
            <p class="m-0">Shopping Cart</p>
        </div>
    </div>
</div>
<!-- Page Header End -->
<!-- Cart Start -->
<div class="container-fluid pt-5">
    <div class="row px-xl-5">
        <div class="col-lg-8 table-responsive mb-5">
            <table class="table table-bordered text-center mb-0">
                <thead class="bg-secondary text-dark">
                    <tr>
                        <th>Products</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Total</th>
                        <th>Remove</th>
                    </tr>
                </thead>
                <tbody class="align-middle">
                    @foreach (var item in Model.cartItems)
                    {
                        <tr class="cart-row" data-id="@item.VariantId">
                            <td class="align-middle"><img src="@ImageSettings.GetImageUrl(ImageSettings.ProudctsImagesFolder,item.ImageUrl)" alt="" style="width: 50px;"> @item.VariantName</td>
                            <td class="align-middle item-price" data-price="@item.Price">$@item.Price</td>
                            <td class="align-middle">
                                <div class="input-group quantity mx-auto" style="width: 100px;">
                                    <div class="input-group-btn">
                                        <button class="btn btn-sm btn-primary btn-minus">
                                            <i class="fa fa-minus"></i>
                                        </button>
                                    </div>
                                    <input type="text" class="form-control form-control-sm bg-secondary text-center qty-input" value="@item.Quantity">
                                    <div class="input-group-btn">
                                        <button class="btn btn-sm btn-primary btn-plus">
                                            <i class="fa fa-plus"></i>
                                        </button>
                                    </div>
                                </div>
                            </td>
                            <td class="align-middle item-total">$@item.TotalPrice</td>
                            <td class="align-middle"><button class="btn btn-sm btn-primary btn-remove"><i class="fa fa-times"></i></button></td>
                        </tr>
                    }
                 
                </tbody>
            </table>
        </div>
        <div class="col-lg-4">
            @{
              // TODO :Add Coupon
             }

           @*  <form class="mb-5" action="">
                <div class="input-group">
                    <input type="text" class="form-control p-4" placeholder="Coupon Code">
                    <div class="input-group-append">
                        <button class="btn btn-primary">Apply Coupon</button>
                    </div>
                </div>
            </form> *@
            <div class="card border-secondary mb-5">
                <div class="card-header bg-secondary border-0">
                    <h4 class="font-weight-semi-bold m-0">Cart Summary</h4>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-3 pt-1">
                        <h6 class="font-weight-medium">Subtotal</h6>
                        <h6 class="font-weight-medium" id="cart-subtotal">$@Model.SubTotal</h6>
                    </div>
                    <div class="d-flex justify-content-between">
                        <h6 class="font-weight-medium">Shipping</h6>
                        <h6 class="font-weight-medium" id="cart-shipping" data-shipping="@Model.Shipping">$@Model.Shipping</h6>
                    </div>
                </div>
                <div class="card-footer border-secondary bg-transparent">
                    <div class="d-flex justify-content-between mt-2">
                        <h5 class="font-weight-bold">Total</h5>
                        <h5 class="font-weight-bold" id="cart-final-total">$@(Model.SubTotal + Model.Shipping)</h5>
                    </div>
                    <a asp-action="Checkout" asp-controller="Order"  class="btn btn-block btn-primary my-3 py-3">Proceed To Checkout</a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Cart End -->
@section Scripts{
    <script>
                $(document).ready(function () {

                function updateCartSummary() {
                let subtotal = 0;

                $(".item-total").each(function () {
                    let val = parseFloat($(this).text().replace('$', ''));
                    subtotal += val;
                });

                let shipping = parseFloat($("#cart-shipping").data("shipping"));
                let total = subtotal + shipping;

                $("#cart-subtotal").text('$' + subtotal.toFixed(2));
                $("#cart-final-total").text('$' + total.toFixed(2));
            }

            $(".btn-plus, .btn-minus").on("click", function () {
                let row = $(this).closest("tr");
                let price = parseFloat(row.find(".item-price").data("price"));
                let qtyInput = row.find(".qty-input");

                
                setTimeout(function() {
                    let qty = parseInt(qtyInput.val());
                    let lineTotal = price * qty;

                    row.find(".item-total").text('$' + lineTotal.toFixed(2));
                    updateCartSummary();

                    // تحديث السيرفر بالأجاكس
                    updateQuantityInDb(row.data("id"), qty);
                }, 50);
            });

            // 3. حذف منتج
            $(".btn-remove").on("click", function () {
                let row = $(this).closest("tr");
                let VariantId = row.data("id");

                Swal.fire({
                    title: 'Are you sure?',
                    text: "Do you want to remove this item?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Yes, delete it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        // نبعت للسيرفر يحذف
                        $.post("/Cart/RemoveItem", { VariantId: VariantId }, function (response) {
                            if (response.success) {
                                row.remove();
                                updateCartSummary();
                                Swal.fire('Deleted!', 'Item has been removed.', 'success');
                            }
                        });
                    }
                });
            });

            function updateQuantityInDb(vId, q) {
                $.post("/Cart/UpdateQuantity", { 
                    VariantId: vId,
                    Quantity: q ,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                });
            }
        });
    </script>
    <script>
                $(document).on("click", ".btn-remove", function (e) {
            e.preventDefault();
            let btn = $(this);
            let row = btn.closest("tr");
            let variantId = row.data("id");
            let token = $('input[name="__RequestVerificationToken"]').val();

            Swal.fire({
                title: 'Are you sure?',
                text: "Delete this product from cart",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, Delete',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Cart/RemoveItem', 
                        type: 'POST',
                        data: {
                            variantId: variantId,
                            __RequestVerificationToken: token
                        },
                        success: function (response) {
                            if (response.success) {
                                // حذف السطر بحركة انيميشن بسيطة
                                row.fadeOut(400, function () {
                                    $(this).remove();
                                    // تحديث الحسابات والـ Badge بعد الحذف
                                    updateCartSummary();
                                    $("#cart-badge-count").text(response.cartCount);

                                    // لو الكارت فضي خالص ممكن تظهر رسالة "الكارت فارغ"
                                    if ($(".cart-row").length === 0) {
                                        location.reload(); // أو اظهر رسالة Cart is Empty
                                    }
                                });
                            } else {
                                Swal.fire('Error', response.message, 'error');
                            }
                        }
                    });
                }
            });
        });
    </script>
}