@section Scripts{
        <script>

             variants = @Html.Raw(Json.Serialize(Model.Variants));
            var userSelection = {};

            $(document).ready(function () {
                // 2. تجميع الاختيارات اللي معمولة checked أصلاً (لو الصفحة فاتحة بـ Variant معين)
                $(".variant-selector:checked").each(function() {
                    var attrId = parseInt($(this).data("attr-id"));
                    var valId = parseInt($(this).data("val-id"));
                    userSelection[attrId] = valId;
                });

                // تشغيل الفحص فوراً عند تحميل الصفحة
                checkMatchingVariant();

                // 3. عند تغيير الاختيار
                $(".variant-selector").on("change", function () {
                    var attrId = parseInt($(this).data("attr-id"));
                    var valId = parseInt($(this).data("val-id"));
                    userSelection[attrId] = valId;
                    checkMatchingVariant();
                });

                function checkMatchingVariant() {
                    var totalAttributesToSelect = @Model.SelectionAttributes.Count;
                    var currentSelectedCount = Object.keys(userSelection).length;

                    if (currentSelectedCount === totalAttributesToSelect) {
                        // تجميع القيم المختارة في مصفوفة أرقام
                        var selectedValues = Object.values(userSelection).map(Number);

                        // البحث عن المطابق (لاحظ استخدام حروف camelCase لو السيرفر محولها)
                        var match = variants.find(function(v) {
                            // جرب v.optionIds لو v.OptionIds مكنتش شغالة
                            var vOptions = v.OptionIds || v.optionIds;
                            return selectedValues.every(id => vOptions.includes(id));
                        });

                        if (match) {
                            updateUI(match);
                        }
                        else {
                            showUnavailable();
                        }
                    }
                }

                function updateUI(variant) {
                    // التعامل مع الأسعار (تأكد من مسميات الحروف برضه price أو Price)
                    var price = variant.Price || variant.price;
                    var offerPrice = variant.OfferPrice || variant.offerPrice;
                    var stock = variant.Stock || variant.stock;
                    var img = variant.ImageUrl || variant.imageUrl;
                    var id = variant.Id || variant.id;

                                var finalPrice = price;

            if (offerPrice && offerPrice > 0 && offerPrice < price) {
                finalPrice = offerPrice;
                var discount = Math.round(((price - offerPrice) / price) * 100);

                // 1. تحديث السعر الأساسي (الجديد)
                $("#current-price").text(offerPrice.toFixed(2) + " EGP");

                // 2. تحديث السعر القديم داخل علامة التشطيب <del>
                $("#old-price del").text(price.toFixed(2) + " EGP");

                // 3. تحديث نسبة الخصم
                $("#discount-badge").text(discount + "% OFF");

                // 4. إظهار قسم العرض
                $("#offer-section").show();
            } else {
                // لو مفيش عرض، اعرض السعر العادي واخفي قسم الخصم
                $("#display-price").text(price.toFixed(2) + " EGP");
                $("#offer-section").hide();
            }

                    $("#current-price").text(finalPrice.toFixed(2) + " EGP");

                    if (img) {
                        $("#main-display-image").attr("src", img);
                    }

                    $("#selectedVariantId").val(id);

                    if (stock > 0) {
                        $("#stock-message").html(`<span class="badge badge-success">In Stock: ${stock}</span>`);
                        $("#btn-add-to-cart").prop("disabled", false);
                    } else {
                        $("#stock-message").html(`<span class="badge badge-danger">Out of Stock</span>`);
                        $("#btn-add-to-cart").prop("disabled", true);
                    }
                }

                function showUnavailable() {
                    $("#current-price").text("Not Available");
                    $("#btn-add-to-cart").prop("disabled", true);
                    $("#stock-message").html("");
                }
            });
        </script>

        <script>
                        $("#addToCartForm").on("submit", function (e) {
                e.preventDefault();
                var vId = $("#selectedVariantId").val();
                var qty = $("#quantityInput").val();

                addToCart(vId, qty);
            });
        </script>
