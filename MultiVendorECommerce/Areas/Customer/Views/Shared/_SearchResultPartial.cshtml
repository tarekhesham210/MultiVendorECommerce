@model IEnumerable<ProductVariantCardVM>

@if (Model.Any())
{
    <ul class="list-group shadow">
        @foreach (var item in Model)
        {
            <li class="list-group-item list-group-item-action border-0">
                <a asp-action="ProductDetails" asp-controller="Home" asp-route-productId="@item.ProductId" asp-route-variantId="@item.Id" class="d-flex align-items-center text-decoration-none text-dark">
                    <img src="@ImageSettings.GetImageUrl(ImageSettings.ProudctsImagesFolder,item.MainImageUrl)" style="width: 40px; height: 40px; object-fit: cover;" class="mr-3 rounded">
                    <div>
                        <div class="font-weight-bold">@item.Name</div>
                        <small class="text-primary">$@item.FinalPrice</small>
                    </div>
                </a>
            </li>
        }
    </ul>
}
else
{
    <div class="list-group-item shadow">No products found.</div>
}

