 @model List<CategoryAttributeVM>

<div id="product-attributes-container">
    <h5 class="mb-3 text-secondary">السمات الأساسية (Fixed Attributes)</h5>
    @{
        int fixedIndex = 0;
    }

    @foreach (var attr in Model.Where(a => !a.IsVariant))
    {
        <div class="form-group mb-3 card p-2 shadow-sm">
            <label class="font-weight-bold">@attr.Name</label>
            <input type="hidden" name="FixedAttributesValues[@fixedIndex].AttributeId" value="@attr.Id" />

            <select name="FixedAttributesValues[@fixedIndex].SelectedOptionId" class="form-control">
                <option value="">-- اختر --</option>
                @foreach (var opt in attr.Options)
                {
                    <option value="@opt.Id" >
                        @opt.Value
                    </option>
                }
            </select>
        </div>
        fixedIndex++;
    }
</div>

<hr />

 <div class="card p-4 mb-4 bg-light border-info">
    <h5 class="mb-3 text-info"><i class="fas fa-plus-circle"></i> إضافة نسخ جديدة (New Variations)</h5>
    <p class="small text-muted">اختر السمات بالأسفل لتوليد مقاسات أو ألوان جديدة لم تكن موجودة:</p>

    @foreach (var attr in Model.Where(a => a.IsVariant))
    {
        <div class="variant-attribute-group mb-3" data-attr-id="@attr.Id" data-attr-name="@attr.Name">
            <label class="font-weight-bold">@attr.Name</label>
            <select class="form-control select-multiple-variants" multiple="multiple" data-placeholder="اختر قيم الـ @attr.Name">
                @foreach (var opt in attr.Options)
                {
                    <option value="@opt.Id" selected="@(opt.Id == attr.SelectedOptionId ? "selected" : null)">@opt.Value</option>
                }
            </select>
        </div>
    }
    <button type="button" id="btnGenerate" class="btn btn-info mt-2">
        <i class="fas fa-magic"></i> توليد النسخ الجديدة في الجدول
    </button>
</div>
 
 

























@* @using PermissionBasedAuz.Shared.Enums
@model List<CategoryAttributeVM>
@{
   // ViewData.TemplateInfo.HtmlFieldPrefix = ViewData["Prefix"]?.ToString();
}

<div id="product-attributes-container">
    @for (int i = 0; i < Model.Count; i++)
    {
        var attr = Model[i];

        <!-- Hidden fields for binding -->
        <input type="hidden" name="Attributes[@i].Id" value="@attr.Id" />
        <input type="hidden" name="Attributes[@i].Name" value="@attr.Name" />
        <input type="hidden" name="Attributes[@i].Type" value="@attr.Type" />
        <input type="hidden" name="Attributes[@i].IsRequired" value="@attr.IsRequired.ToString().ToLower()" />

        @if (attr.Type == CategoryAttributeType.FixedSelect || attr.Type == CategoryAttributeType.CustomSelect)
        {
            <div class="d-flex mb-3">
                <p class="text-dark font-weight-medium mb-0 mr-3">
                    @attr.Name :
                    @if (attr.IsRequired)
                    {
                        <span class="text-danger">*</span>
                    }
                </p>

                <div>
                    @for (int j = 0; j < attr.Options.Count; j++)
                    {
                        var option = attr.Options[j];
                        <div class="custom-control custom-checkbox custom-control-inline">
                            <input type="checkbox"
                                   class="custom-control-input"
                                   id="attr-@i-opt-@j"
                                   name="Attributes[@i].Values"
                                   value="@option.Value"
                                   @(attr.Values.Contains(option.Value) ? "checked" : "") />
                            <label class="custom-control-label" for="attr-@i-opt-@j">@option.Value</label>
                        </div>
                    }
                </div>
            </div>
        }
        else if (attr.Type == CategoryAttributeType.Boolean)
        {
            <div class="custom-control custom-checkbox mb-3">
                <input type="checkbox"
                       class="custom-control-input"
                       id="attr-bool-@i"
                       name="Attributes[@i].Values"
                       value="true"
                       @(attr.Values.Contains("true") ? "checked" : "") />
                <label class="custom-control-label" for="attr-bool-@i">@attr.Name</label>
            </div>
        }
        else // Text or Number
        {
            <div class="mb-3">
                <label class="text-dark font-weight-medium">
                    @attr.Name
                    @if (attr.IsRequired)
                    {
                        <span class="text-danger">*</span>
                    }
                </label>
                @{
                    // 1. نتأكد من النوع
                    string typeStr = (attr.Type == CategoryAttributeType.Number) ? "number" : "text";

                    // 2. نجيب القيمة بأمان تام
                    string val = "";
                    if (attr.Values != null && attr.Values.Count > 0)
                    {
                        val = attr.Values[0];
                    }

                    // 3. نجهز الـ Required كـ String
                    string reqAttr = attr.IsRequired ? "required='required'" : "";
                }
                <span>Debug: Type is @attr.Type and Values count is @(attr.Values?.Count ?? -1)</span>
                @* استخدمنا HTML خالص هنا ونادينا المتغيرات بـ @ فقط 
                <input type="@typeStr"
                       class="form-control"
                       name="Attributes[@i].Values[0]"
                       value="@val"
                       @Html.Raw(reqAttr) />
            </div>
        }
    }
</div>
