@using Microsoft.AspNetCore.Identity
@model Dictionary<UserType, List<ApplicationRole>>
@{
    ViewData["Title"] = "Roles";
}
<h2>Roles Management</h2>
<a asp-action="CreateRole" class="btn btn-success mb-3">Create New Role</a>
@foreach (var userTypeRoles in Model)
{
    <h3>@userTypeRoles.Key.ToString() Roles</h3>
    <table class="table">
        <thead>
            <tr>
                <th>Role Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var role in userTypeRoles.Value)
            {
                <tr>
                    <td>@role.Name</td>
                    <td>
                        <a asp-action="ManageRolePermissions" asp-route-id="@role.Id" class="btn btn-primary">Manage </a>
                        <form asp-action="DeleteRole" asp-route-id="@role.Id" method="post" onsubmit="return confirm('Are you sure?');" class="d-inline">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}



