@model NewRoleVM
<form asp-action="CreateRole" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
   
    <div class="form-group">
    <label asp-for="Name" class="form-label">Role Name</label>
    <input type="text" asp-for="Name" placeholder="Role Name" class="form-control" />
    <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="RoleType" class="control-label"></label>
        <select asp-for="RoleType"
                asp-items="Model.Types"
                class="form-control">
            <option value="">-- Choose Role Type --</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary mt-3">Create Role</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}